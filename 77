import random

nombre_random = random.randint(1,10)
choisir_nombre = int(input("Choisi un nombre entre 1 et 10: "))

while choisir_nombre != nombre_random:
    if choisir_nombre < nombre_random:
        print("Trop petit")
    else:
        print("Trop grand")
    
    choisir_nombre = int(input("Choisi un nombre entre 1 et 10: "))

print("Vous avez gagné")
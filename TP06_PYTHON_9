def calculatrice(nombre1, nombre2, operateur):
    if operateur == "+":
        print(nombre1+nombre2)
    elif operateur == "-":
        print(nombre1-nombre2)
    elif operateur == "/":
        if nombre1 and nombre2>0:
            print(nombre1/nombre2)
        else:
            print("Division par 0 impossible")
    elif operateur == "*":
        print(nombre1*nombre2)
calculatrice(19, 15,"-")